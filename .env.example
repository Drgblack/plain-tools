# Anthropic (AI routes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# API CORS allowlist primary origin (www variant is allowed automatically)
ALLOWED_ORIGIN=https://plain.tools

# Brevo (support email route)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=no-reply@plain.tools
SUPPORT_EMAIL=your-support@email.com
WAITLIST_EMAIL=your-support@email.com

# Stripe subscriptions (Plain Pro)
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_monthly_xxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_annual_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Public IDs consumed by the pricing client
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_monthly_xxx
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=price_annual_xxx

# Clerk authentication (required for Pro subscription flows)
CLERK_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
# Optional: set to your production domain for redirect URLs in Stripe flows
NEXT_PUBLIC_APP_URL=https://plain.tools

# Upstash Redis (API rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Axiom monitoring (structured logs + observability)
# Dataset name appears in browser telemetry config and server-side logger routing.
NEXT_PUBLIC_AXIOM_DATASET=your_axiom_dataset_name
# Server-side token used for log ingestion from API/server runtime.
AXIOM_TOKEN=your_axiom_token

# SEO/IndexNow scripts
SITE_URL=https://plain.tools
INDEXNOW_KEY=your_indexnow_key

# Note: NODE_ENV is set automatically by Next.js/Vercel.
